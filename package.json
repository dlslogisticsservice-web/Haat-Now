{
  "name": "haat-now",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "dev:live": "node scripts/live.cjs dev",
    "build": "vite build && node scripts/gen-version.cjs",
    "build:live": "node scripts/live.cjs build",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit && node scripts/check-architecture.cjs",
    "check:arch": "node scripts/check-architecture.cjs",
    "test:website": "node scripts/test-website.cjs",
    "bench:website": "tsx src/website-platform/__bench__/bench.ts",
    "gen:icons": "node scripts/gen-icons.cjs && node scripts/gen-android-icons.cjs",
    "gen:store": "node scripts/gen-store-assets.cjs"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@supabase/supabase-js": "^2.108.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vis.gl/react-google-maps": "^1.8.3",
    "@vitejs/plugin-react": "^5.0.4",
    "i18next": "^26.3.1",
    "lottie-react": "^2.4.1",
    "lucide-react": "^0.546.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-i18next": "^17.0.8",
    "recharts": "^3.9.0",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "puppeteer": "^25.1.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
