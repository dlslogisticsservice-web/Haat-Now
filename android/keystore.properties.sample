# Android release signing — copy to android/keystore.properties (gitignored) and fill in.
# Generate a keystore once:
#   keytool -genkey -v -keystore haatnow-release.jks -keyalg RSA -keysize 2048 -validity 10000 -alias haatnow
storeFile=haatnow-release.jks
storePassword=CHANGE_ME
keyAlias=haatnow
keyPassword=CHANGE_ME
